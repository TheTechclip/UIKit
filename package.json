{
  "name": "@musecat/uikit",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "High-performance Next.js React UI component library with Squircle shapes, theme tokens, and gesture-driven overlays",
  "author": "Musecat Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheTechclip/UIKit.git"
  },
  "bugs": {
    "url": "https://github.com/TheTechclip/UIKit/issues"
  },
  "homepage": "https://musecat.app",
  "keywords": [
    "react",
    "nextjs",
    "uikit",
    "components",
    "squircle",
    "framer-motion",
    "dialog",
    "bottom-sheet",
    "date-picker"
  ],
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./*": "./*"
  },
  "files": [
    "index.ts",
    "packages/",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.scss"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "lint": "biome check",
    "format": "prettier --write . && biome format --write",
    "lint:css": "stylelint \"packages/**/*.scss\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@musecat/functionkit": "^1.0.1",
    "@use-funnel/browser": "^0.0.17",
    "clsx": "^2.1.1",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "embla-carousel-wheel-gestures": "^8.1.0",
    "figma-squircle": "1.1.0",
    "maplibre-gl": "^5.24.0",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "next-intl": "^4.13.1",
    "prismjs": "^1.30.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "^0.35.3",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "sass": "^1.101.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "stylelint-scss": "^7.2.0",
    "ts-morph": "^28.0.0",
    "typescript": "^6",
    "vitest": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10"
  }
}
