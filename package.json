{
  "name": "uikit-root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheTechclip/UIKit.git"
  },
  "scripts": {
    "lint": "pnpm -r lint",
    "format": "prettier --write . && pnpm -r format",
    "lint:css": "pnpm -F @musecat/uikit lint:css",
    "typecheck": "pnpm -F @musecat/uikit typecheck",
    "test": "pnpm -F @musecat/uikit test",
    "test:coverage": "pnpm -F @musecat/uikit test:coverage",
    "build": "pnpm -F @musecat/uikit build",
    "publish": "pnpm -F @musecat/uikit publish"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "prettier": "^3.9.5",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "stylelint-scss": "^7.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
